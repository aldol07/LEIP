APP_ENV=development
API_PREFIX=/api/v1

DATABASE_URL=sqlite:///./leip.db
REDIS_URL=redis://redis:6379/0

JWT_SECRET_KEY=replace-with-secure-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440
WORKER_INTERNAL_TOKEN=local-worker-token

USE_MOCK=true
MOCK_LIVESCORE_PATH=mock_livescore.json
THESPORTSDB_API_KEY=123
THESPORTSDB_BASE_URL=https://www.thesportsdb.com/api/v1/json

GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_MAX_RETRIES=4
GEMINI_INITIAL_BACKOFF_MS=1000
GEMINI_MAX_BACKOFF_MS=12000
GEMINI_MIN_INTERVAL_MS=700
GEMINI_REQUEST_TIMEOUT_MS=12000

WORKER_ADMIN_PORT=3001
BACKEND_INTERNAL_URL=http://backend:8000/api/v1/internal
